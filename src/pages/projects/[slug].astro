---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import ProjectCaseI18n from '../../components/ProjectCaseI18n.astro';
import {
  getAllProjects,
  getProjectBySlug,
  getProjectIndex,
  getProjectContent,
  getProfile,
  getProjectLabels,
  resolveLang,
  getProjectsListHref,
  getCaseI18nPayload,
} from '../../lib/projects';

export function getStaticPaths() {
  return getAllProjects().map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = slug ? getProjectBySlug(slug) : undefined;

if (!project) {
  return Astro.redirect('/404');
}

const lang = resolveLang(Astro.url.searchParams.get('lang'));
const content = getProjectContent(project, lang);
const profile = getProfile(lang);
const labels = getProjectLabels(lang);
const projectIndex = getProjectIndex(project.slug);
const totalProjects = getAllProjects().length;
const pageNumber = projectIndex + 1;
const descriptionParagraphs = content.description.split('\n\n').filter(Boolean);
const counterText = labels.counter
  .replace('{current}', String(pageNumber))
  .replace('{total}', String(totalProjects));
const caseI18n = getCaseI18nPayload(project, pageNumber, totalProjects);
---

<ProjectLayout
  title={`${content.title} — Farhan Muzaki`}
  description={descriptionParagraphs[0] ?? content.title}
  lang={lang}
>
  <ProjectCaseI18n payload={caseI18n} />

  <main id="main-content" class=" p-10 sm:pb-10">
      

      <!-- Sidebar kiri + konten/gambar kanan -->
      <div class="project-case-layout">
        <aside class="project-case-sidebar pt-6" aria-label="Project metadata">
          <div class="project-case-field">
            <a
              href={getProjectsListHref(lang)}
              class="inline-block mb-6 font-mono text-[0.75rem] text-text-muted border-b border-border-light pb-px transition-colors duration-fast hover:text-text-primary hover:border-text-secondary"
              data-i18n-case-label="back"
            >
              {labels.back}
            </a>
          </div>
          <div class="project-case-field">
            <p class="project-case-label" data-i18n-case-label="title">{labels.title}</p>
            <p class="project-case-value project-case-value--strong" data-i18n-case-value="title">{content.title}</p>
          </div>
          <div class="project-case-field">
            <p class="project-case-label" data-i18n-case-label="year">{labels.year}</p>
            <p class="project-case-value" data-i18n-case-value="year">{content.year}</p>
          </div>
          <div class="project-case-field">
            <p class="project-case-label" data-i18n-case-label="role">{labels.role}</p>
            <p class="project-case-value" data-i18n-case-value="role">{content.role}</p>
          </div>
          <div class="project-case-field">
            <p class="project-case-label" data-i18n-case-label="link">{labels.link}</p>
            <p class="project-case-value">
              <a
                href={content.publicationLink}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-blue border-b border-current pb-px transition-opacity duration-fast hover:opacity-70"
                data-i18n-case-value="publicationLabel"
              >
                {content.publicationLabel}
              </a>
            </p>
          </div>
        </aside>

        <div class="project-case-main">
          <div class="project-case-description-head">
            <p class="project-case-label" data-i18n-case-label="description">{labels.description}</p>
            <p class="project-case-counter" data-i18n-case-value="counter">{counterText}</p>
          </div>

          <div class="project-case-description" data-i18n-case-value="description">
            {descriptionParagraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <figure class="project-case-media">
            <img
              src={project.heroImage}
              alt={content.title}
              loading="eager"
              decoding="async"
              class="project-case-image"
            />
          </figure>
        </div>
      </div>

      <!-- Footer info -->
      <footer class="project-case-footer">
        <div class="project-case-footer-col">
          <p class="project-case-label" data-i18n-case-label="footerName">{labels.footerName}</p>
          <p class="project-case-footer-value" data-i18n-case-value="name">{profile.name}</p>
        </div>
        <div class="project-case-footer-col">
          <p class="project-case-label" data-i18n-case-label="footerUniversity">{labels.footerUniversity}</p>
          <p class="project-case-footer-value" data-i18n-case-value="university">{profile.university}</p>
        </div>
        <div class="project-case-footer-col">
          <p class="project-case-label" data-i18n-case-label="footerContact">{labels.footerContact}</p>
          <p class="project-case-footer-value" data-i18n-case-value="contact">{profile.contact}</p>
        </div>
        <div class="project-case-footer-col project-case-footer-col--note">
          <p class="project-case-footer-note" data-i18n-case-value="footerNote">{profile.footerNote}</p>
        </div>
      </footer>
    </main>
</ProjectLayout>

<style>
  .project-case-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .project-case-layout {
      grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
      gap: 2rem 2.5rem;
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .project-case-layout {
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 2.5rem 3rem;
    }
  }

  .project-case-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .project-case-sidebar {
      position: sticky;
      top: calc(1.5rem + var(--safe-top, 0px));
    }
  }

  .project-case-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-case-field {
    min-width: 0;
  }

  .project-case-label {
    margin: 0 0 0.3rem;
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-primary, #f0f0f0);
  }

  .project-case-value {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-text-secondary, #9a9a9a);
    word-break: break-word;
  }

  .project-case-value--strong {
    color: var(--color-text-primary, #f0f0f0);
    font-weight: 600;
  }

  .project-case-description-head {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  @media (min-width: 640px) {
    .project-case-description-head {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  .project-case-counter {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--color-text-muted, #5e5e5e);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-case-description {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-case-description :global(p) {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-text-secondary, #9a9a9a);
  }

  .project-case-media {
    margin: 0.5rem 0 0;
    border: 1px solid #262626;
    border-radius: 6px;
    overflow: hidden;
    background: #141414;
  }

  .project-case-image {
    display: block;
    width: 100%;
    height: auto;
    min-height: 200px;
    max-height: min(72vh, 680px);
    object-fit: cover;
    object-position: center top;
  }

  @media (min-width: 768px) {
    .project-case-image {
      min-height: 320px;
    }
  }

  .project-case-footer {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid #262626;
  }

  @media (min-width: 640px) {
    .project-case-footer {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .project-case-footer {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      padding-top: 1.5rem;
    }
  }

  .project-case-footer-col {
    min-width: 0;
  }

  .project-case-footer-value {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-text-muted, #5e5e5e);
    word-break: break-word;
  }

  .project-case-footer-col--note {
    display: flex;
    align-items: flex-end;
  }

  @media (max-width: 1023px) {
    .project-case-footer-col--note {
      grid-column: 1 / -1;
      align-items: flex-start;
    }
  }

  .project-case-footer-note {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--color-text-secondary, #9a9a9a);
  }
</style>
