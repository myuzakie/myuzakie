---
import ReviewLayout from '../../../layouts/ReviewLayout.astro';
import { getReviewProjects } from '../../../lib/reviewProjects';

const reviewProjects = getReviewProjects('en').slice(0, 4);
---

<ReviewLayout
  title="Apple Developer Academy Review — Muzakie Portfolio"
  description="A focused portfolio review page prepared for Apple Developer Academy reviewers."
>
  <div class="rp-root">

    <!-- Nav bar -->
    <header class="rp-nav">
      <div class="rp-nav-inner">
        <a class="rp-brand" href="/">
          <div class="rp-brand-avatar">
            <img src="/images/profile_picture.jpg" alt="Farhan Muzaki" />
          </div>
          <span class="rp-brand-name">Muzakie</span>
        </a>

        <div class="rp-nav-right">
          <!-- Apple Academy logo badge -->
          <a
            href="https://www.linkedin.com/school/apple-developer-academy-indonesia/"
            target="_blank"
            rel="noopener"
            class="rp-academy-badge"
            title="Apple Developer Academy Indonesia"
          >
            <img
              src="https://media.licdn.com/dms/image/v2/C510BAQHyTIzJP41l9w/company-logo_200_200/company-logo_200_200/0/1631406350980/apple_developer_academy_indonesia_logo?e=2147483647&v=beta&t=SzBY5ZD_hAVR52ptR0sSodtvakY1abxaYnm-7qoV7Q8"
              alt="Apple Developer Academy Indonesia"
              width="24"
              height="24"
            />
            <span>Apple Developer Academy</span>
          </a>

          <span class="rp-pill">Reviewer Access</span>
        </div>
      </div>
    </header>

    <!-- Hero section -->
    <section class="rp-hero">
      <div class="rp-hero-inner">
        <p class="rp-eyebrow">Portfolio Review · 2025</p>
        <h1 class="rp-headline">
          Built with<br />
          purpose.<br />
          Designed<br />
          to ship.
        </h1>
        <p class="rp-subhead">
          Farhan Muzaki — Product Designer &amp; Developer.
          These works show how I think through problems,
          make interface decisions, and bring ideas to life
          in production.
        </p>

        <!-- Why this page exists -->
        <div class="rp-context-card">
          <p class="rp-context-label">Why this page?</p>
          <p class="rp-context-body">
            This is a curated, reviewer-focused view of my portfolio.
            Each case study is structured to walk you through
            problem → process → outcome — not just final screens.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="rp-divider"></div>

    <!-- Projects section -->
    <section class="rp-projects">
      <div class="rp-projects-inner">
        <div class="rp-section-header">
          <div>
            <p class="rp-section-label">Selected Work</p>
            <h2 class="rp-section-title">Case Studies</h2>
          </div>
          <a href="/review/apple-academy/projects" class="rp-see-all">
            View all
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Why these projects -->
        <p class="rp-selection-note">
          Projects selected to demonstrate range across UI, product thinking, and technical implementation.
        </p>

        <div class="rp-project-list">
          {reviewProjects.map((project, i) => (
            <a
              class="rp-project-row"
              href={`/review/apple-academy/projects/${project.slug}`}
              aria-label={`Open case study: ${project.title}`}
            >
              <div class="rp-project-num">0{i + 1}</div>
              <div class="rp-project-info">
                <h3 class="rp-project-title">{project.title}</h3>
                <p class="rp-project-desc">{project.description}</p>
              </div>
              <div class="rp-project-meta">
                <span class="rp-project-tag">Case Study</span>
              </div>
              <div class="rp-project-arrow">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="rp-divider"></div>

    <!-- About me for reviewers -->
    <section class="rp-about">
      <div class="rp-about-inner">
        <div class="rp-about-label-col">
          <p class="rp-section-label">About</p>
        </div>
        <div class="rp-about-content">
          <h2 class="rp-about-title">Who I am</h2>
          <p class="rp-about-body">
            I'm Farhan Muzaki — a Product Designer and Developer based in Jakarta, Indonesia.
            I bridge design and engineering: I design in Figma, and I build in React, Webflow, and TypeScript.
            Currently working at PT. Next TI.
          </p>
          <div class="rp-about-tags">
            <span>UI Design</span>
            <span>Product Thinking</span>
            <span>Front-end Dev</span>
            <span>Jakarta, Indonesia</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="rp-footer">
      <div class="rp-footer-inner">
        <p>© 2025 Farhan Muzaki · <a href="/">Full Portfolio</a></p>
        <p class="rp-footer-note">This page is reviewer-only access</p>
      </div>
    </footer>

  </div>
</ReviewLayout>

<style>
  /* ─── Reset & Root ─────────────────────────────────────── */
  .rp-root {
    min-height: 100svh;
    background: #ffffff;
    color: #1d1d1f;
    /* Apple SF Pro system font */
    font-family:
      -apple-system,
      BlinkMacSystemFont,
      'SF Pro Display',
      'SF Pro Text',
      'Helvetica Neue',
      Arial,
      sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── Nav ──────────────────────────────────────────────── */
  .rp-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
  }

  .rp-nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .rp-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #1d1d1f;
  }

  .rp-brand-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    overflow: hidden;
    border: 1.5px solid rgba(0,0,0,0.1);
  }

  .rp-brand-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .rp-brand-name {
    font-size: 15px;
    font-weight: 590;
    letter-spacing: -0.02em;
    color: #1d1d1f;
  }

  .rp-nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rp-academy-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px 5px 6px;
    border-radius: 999px;
    background: rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.08);
    text-decoration: none;
    color: #1d1d1f;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: background 0.15s ease;
  }

  .rp-academy-badge:hover {
    background: rgba(0,0,0,0.07);
  }

  .rp-academy-badge img {
    width: 20px;
    height: 20px;
    border-radius: 5px;
    object-fit: cover;
  }

  .rp-pill {
    display: inline-flex;
    align-items: center;
    height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(29,29,31,0.56);
    background: rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.08);
  }

  /* ─── Hero ─────────────────────────────────────────────── */
  .rp-hero {
    padding: 80px 24px 72px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .rp-hero-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .rp-eyebrow {
    margin: 0 0 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0071e3;
  }

  .rp-headline {
    margin: 0 0 28px;
    font-size: clamp(52px, 8vw, 88px);
    line-height: 1.0;
    letter-spacing: -0.05em;
    font-weight: 700;
    color: #1d1d1f;
    text-wrap: balance;
  }

  .rp-subhead {
    margin: 0 0 36px;
    max-width: 540px;
    font-size: clamp(17px, 1.8vw, 21px);
    line-height: 1.5;
    letter-spacing: -0.022em;
    color: rgba(29,29,31,0.60);
    font-weight: 400;
  }

  .rp-context-card {
    display: inline-block;
    padding: 16px 20px;
    border-radius: 14px;
    background: rgba(0,113,227,0.05);
    border: 1px solid rgba(0,113,227,0.12);
    max-width: 480px;
  }

  .rp-context-label {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #0071e3;
  }

  .rp-context-body {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(29,29,31,0.72);
    letter-spacing: -0.01em;
  }

  /* ─── Divider ─────────────────────────────────────────── */
  .rp-divider {
    height: 1px;
    background: rgba(0,0,0,0.06);
    margin: 0;
  }

  /* ─── Projects ────────────────────────────────────────── */
  .rp-projects {
    padding: 64px 24px 72px;
  }

  .rp-projects-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .rp-section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .rp-section-label {
    margin: 0 0 4px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(29,29,31,0.40);
  }

  .rp-section-title {
    margin: 0;
    font-size: 28px;
    font-weight: 680;
    letter-spacing: -0.04em;
    color: #1d1d1f;
    line-height: 1.1;
  }

  .rp-see-all {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 14px;
    font-weight: 500;
    color: #0071e3;
    text-decoration: none;
    letter-spacing: -0.01em;
    padding-bottom: 2px;
    transition: opacity 0.15s;
  }

  .rp-see-all:hover { opacity: 0.72; }

  .rp-selection-note {
    margin: 0 0 32px;
    font-size: 14px;
    color: rgba(29,29,31,0.44);
    letter-spacing: -0.01em;
  }

  /* ─── Project list rows ───────────────────────────────── */
  .rp-project-list {
    display: flex;
    flex-direction: column;
  }

  .rp-project-row {
    display: grid;
    grid-template-columns: 44px 1fr auto 40px;
    align-items: center;
    gap: 20px;
    padding: 22px 14px;
    border-top: 1px solid rgba(0,0,0,0.07);
    text-decoration: none;
    color: #1d1d1f;
    transition: background 0.15s ease;
    border-radius: 12px;
    margin-inline: -14px;
  }

  .rp-project-row:last-child {
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

  .rp-project-row:hover {
    background: rgba(0,0,0,0.025);
  }

  .rp-project-row:hover .rp-project-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .rp-project-num {
    font-size: 13px;
    font-weight: 620;
    letter-spacing: -0.02em;
    color: rgba(29,29,31,0.28);
    font-variant-numeric: tabular-nums;
  }

  .rp-project-info {
    min-width: 0;
  }

  .rp-project-title {
    margin: 0 0 4px;
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 650;
    letter-spacing: -0.035em;
    color: #1d1d1f;
    line-height: 1.15;
  }

  .rp-project-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(29,29,31,0.54);
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .rp-project-meta {
    display: flex;
    align-items: center;
  }

  .rp-project-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(0,0,0,0.05);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(29,29,31,0.54);
    white-space: nowrap;
  }

  .rp-project-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(29,29,31,0.32);
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  /* ─── About section ───────────────────────────────────── */
  .rp-about {
    padding: 64px 24px;
  }

  .rp-about-inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 40px;
    align-items: start;
  }

  .rp-about-label-col {
    padding-top: 4px;
  }

  .rp-about-title {
    margin: 0 0 16px;
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 680;
    letter-spacing: -0.04em;
    color: #1d1d1f;
    line-height: 1.1;
  }

  .rp-about-body {
    margin: 0 0 20px;
    font-size: 17px;
    line-height: 1.6;
    color: rgba(29,29,31,0.68);
    letter-spacing: -0.022em;
    max-width: 560px;
  }

  .rp-about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .rp-about-tags span {
    display: inline-block;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,0.1);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: rgba(29,29,31,0.60);
  }

  /* ─── Footer ──────────────────────────────────────────── */
  .rp-footer {
    border-top: 1px solid rgba(0,0,0,0.06);
    padding: 28px 24px;
  }

  .rp-footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .rp-footer p {
    margin: 0;
    font-size: 13px;
    color: rgba(29,29,31,0.44);
    letter-spacing: -0.01em;
  }

  .rp-footer a {
    color: #0071e3;
    text-decoration: none;
  }

  .rp-footer-note {
    font-size: 12px !important;
  }

  /* ─── Responsive ──────────────────────────────────────── */
  @media (max-width: 720px) {
    .rp-hero { padding: 52px 20px 48px; }
    .rp-projects { padding: 48px 20px 52px; }
    .rp-about { padding: 48px 20px; }

    .rp-about-inner {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .rp-about-label-col {
      padding-top: 0;
    }

    .rp-project-row {
      grid-template-columns: 36px 1fr 40px;
      padding-inline: 10px;
      margin-inline: -10px;
    }

    .rp-project-meta { display: none; }

    .rp-project-arrow {
      opacity: 1;
      transform: none;
    }

    .rp-academy-badge span {
      display: none;
    }

    .rp-footer-inner {
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .rp-nav-inner { padding: 0 16px; }
    .rp-hero { padding: 40px 16px 40px; }
    .rp-projects { padding: 36px 16px 44px; }
    .rp-about { padding: 36px 16px; }
    .rp-footer { padding: 24px 16px; }
    .rp-section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      transition: none !important;
    }
  }
</style>