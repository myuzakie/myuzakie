---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — Farhan Muzaki">
  <Nav />
  <div class="layout-shell layout-page">
    <main class="layout-content flex flex-col items-start justify-center py-12 sm:py-20">
      <p class="font-mono text-[3rem] sm:text-[5rem] font-light text-border-light leading-none mb-4">404</p>
      <h1 class="font-display text-[1.8rem] font-bold text-text-primary mb-3">Página no encontrada</h1>
      <p class="font-mono text-[0.85rem] text-text-muted mb-8">La página que buscas no existe o fue movida.</p>
      <a
        href="/"
        class="font-mono text-[0.85rem] text-accent-blue border-b border-current pb-0.5 transition-opacity duration-fast hover:opacity-70"
      >
        ← Volver al inicio
      </a>
    </main>
    <Footer />
  </div>
</BaseLayout>
