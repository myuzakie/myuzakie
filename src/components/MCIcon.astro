---
interface Props {
  icon:
    | 'redstone'
    | 'heart'
    | 'diamond'
    | 'emerald'
    | 'gold'
    | 'crafting-table'
    | 'furnace'
    | 'grass-block'
    | 'controller'
    | 'city'
    | 'fire'
    | 'star'
    | 'apple'
    | 'book';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { icon, size = 'md', class: className } = Astro.props;

const sizeMap = {
  sm: '16px',
  md: '20px',
  lg: '24px',
};

const twSizeMap = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const currentSize = sizeMap[size];
const twSize = twSizeMap[size];

// SVG-based Minecraft-style icons
const icons: Record<string, string> = {
  redstone:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="28" height="28" fill="#8B0000"/><rect x="4" y="4" width="24" height="24" fill="#D41818"/><circle cx="16" cy="16" r="4" fill="#8B0000"/><rect x="8" y="14" width="16" height="4" fill="#8B0000"/><rect x="14" y="8" width="4" height="16" fill="#8B0000"/></svg>',

  heart:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="8" width="28" height="24" fill="#FF1744"/><path d="M6 8 L10 4 L14 8 L18 2 L22 8 L26 4 L30 8" fill="none"/><rect x="6" y="10" width="4" height="4" fill="#FF1744"/><rect x="22" y="10" width="4" height="4" fill="#FF1744"/><polygon points="16,28 8,22 8,14 24,14 24,22" fill="#FF1744"/></svg>',

  diamond:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><polygon points="16,2 30,16 16,30 2,16" fill="#00E5FF"/><polygon points="16,2 30,16 16,30 2,16" fill="none" stroke="#0097A7" stroke-width="2"/><line x1="2" y1="16" x2="30" y2="16" stroke="#0097A7" stroke-width="1"/><line x1="16" y1="2" x2="16" y2="30" stroke="#0097A7" stroke-width="1"/></svg>',

  emerald:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><polygon points="16,2 30,16 16,30 2,16" fill="#00C853"/><polygon points="16,2 30,16 16,30 2,16" fill="none" stroke="#00701A" stroke-width="2"/><rect x="8" y="8" width="16" height="16" fill="none" stroke="#00701A" stroke-width="1"/></svg>',

  gold:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="24" height="24" fill="#FFD700"/><rect x="4" y="4" width="24" height="24" fill="none" stroke="#B8860B" stroke-width="2"/><line x1="10" y1="4" x2="10" y2="28" stroke="#B8860B" stroke-width="1"/><line x1="16" y1="4" x2="16" y2="28" stroke="#B8860B" stroke-width="1"/><line x1="22" y1="4" x2="22" y2="28" stroke="#B8860B" stroke-width="1"/></svg>',

  'crafting-table':
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="24" height="24" fill="#8B4513"/><rect x="4" y="4" width="24" height="24" fill="none" stroke="#5C2E0F" stroke-width="2"/><line x1="12" y1="4" x2="12" y2="28" stroke="#5C2E0F" stroke-width="1"/><line x1="20" y1="4" x2="20" y2="28" stroke="#5C2E0F" stroke-width="1"/><line x1="4" y1="12" x2="28" y2="12" stroke="#5C2E0F" stroke-width="1"/><line x1="4" y1="20" x2="28" y2="20" stroke="#5C2E0F" stroke-width="1"/></svg>',

  furnace:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="24" height="24" fill="#5A5A5A"/><rect x="4" y="4" width="24" height="24" fill="none" stroke="#2A2A2A" stroke-width="2"/><rect x="8" y="8" width="8" height="8" fill="#FF6B35"/><rect x="16" y="8" width="8" height="8" fill="#5A5A5A"/><rect x="8" y="16" width="8" height="8" fill="#5A5A5A"/><rect x="16" y="16" width="8" height="8" fill="#5A5A5A"/></svg>',

  'grass-block':
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="10" width="24" height="18" fill="#6B5D36"/><rect x="4" y="4" width="24" height="6" fill="#2D9F3D"/><line x1="4" y1="10" x2="28" y2="10" stroke="#1C5F2D" stroke-width="1"/></svg>',

  controller:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path d="M6 10 Q4 10 4 14 L4 24 Q4 26 6 26 L26 26 Q28 26 28 24 L28 14 Q28 10 26 10 Z" fill="#333"/><circle cx="10" cy="16" r="2.5" fill="#666"/><circle cx="14" cy="16" r="2.5" fill="#666"/><rect x="20" y="14" width="3" height="3" fill="#666"/><rect x="24" y="14" width="3" height="3" fill="#666"/></svg>',

  city:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="12" width="6" height="16" fill="#9E9E9E"/><rect x="2" y="12" width="6" height="16" fill="none" stroke="#424242" stroke-width="1"/><rect x="4" y="14" width="2" height="2" fill="#B3E5FC"/><rect x="4" y="18" width="2" height="2" fill="#B3E5FC"/><rect x="4" y="22" width="2" height="2" fill="#B3E5FC"/><rect x="10" y="8" width="6" height="20" fill="#9E9E9E"/><rect x="10" y="8" width="6" height="20" fill="none" stroke="#424242" stroke-width="1"/><rect x="12" y="10" width="2" height="2" fill="#B3E5FC"/><rect x="12" y="14" width="2" height="2" fill="#B3E5FC"/><rect x="12" y="18" width="2" height="2" fill="#B3E5FC"/><rect x="18" y="12" width="6" height="16" fill="#9E9E9E"/><rect x="18" y="12" width="6" height="16" fill="none" stroke="#424242" stroke-width="1"/><rect x="20" y="14" width="2" height="2" fill="#B3E5FC"/><rect x="20" y="18" width="2" height="2" fill="#B3E5FC"/><rect x="20" y="22" width="2" height="2" fill="#B3E5FC"/><rect x="24" y="18" width="4" height="10" fill="#8B4513"/></svg>',

  fire:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path d="M16 2 Q18 8 18 12 Q18 18 14 20 Q10 18 10 12 Q10 8 12 2 Z" fill="#FF6B35"/><path d="M16 4 Q17 8 17 11 Q17 16 14 18 Q11 16 11 11 Q11 8 12 4 Z" fill="#FFD700"/></svg>',

  star:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><polygon points="16,2 20,12 30,12 22,18 26,28 16,22 6,28 10,18 2,12 12,12" fill="#FFD700"/><polygon points="16,2 20,12 30,12 22,18 26,28 16,22 6,28 10,18 2,12 12,12" fill="none" stroke="#FFA500" stroke-width="1"/></svg>',

  apple:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><ellipse cx="16" cy="18" rx="10" ry="12" fill="#C41E3A"/><ellipse cx="16" cy="18" rx="10" ry="12" fill="none" stroke="#8B0000" stroke-width="1"/><rect x="14" y="2" width="4" height="8" fill="#6B4423"/><ellipse cx="18" cy="6" rx="2" ry="3" fill="#2D5016"/></svg>',

  book:
    '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path d="M4 6 L16 4 L28 6 L28 26 L16 28 L4 26 Z" fill="#8B4513"/><path d="M4 6 L16 4 L28 6 L28 26 L16 28 L4 26 Z" fill="none" stroke="#654321" stroke-width="1.5"/><line x1="16" y1="4" x2="16" y2="28" stroke="#654321" stroke-width="1"/><line x1="8" y1="8" x2="14" y2="10" stroke="#D2691E" stroke-width="1"/><line x1="8" y1="14" x2="14" y2="16" stroke="#D2691E" stroke-width="1"/><line x1="18" y1="10" x2="24" y2="12" stroke="#D2691E" stroke-width="1"/><line x1="18" y1="16" x2="24" y2="18" stroke="#D2691E" stroke-width="1"/></svg>',
};

const svgContent = icons[icon] || icons.redstone;
---

<span
  class:list={['inline-block align-middle flex-shrink-0 [&_svg]:block', twSize, `[&_svg]:w-[${currentSize}] [&_svg]:h-[${currentSize}]`, className || '']}
  set:html={svgContent}
/>
