---
import { getTranslation } from "../i18n/translations";

interface Props {
  lang?: "en" | "id" | "de";
}
const { lang = "en" } = Astro.props;
const t = getTranslation(lang as any);

const experience = t.experience.items;
---

<section class="experience-section al">
  <h2 class="section-title">{t.experience.title}</h2>

  <div class="experience-list">
    {experience.map((job) => (
      <div class="experience-item">
        <div class="company-logo bg-white">
          {job.logoText ? (
            <span class="logo-text">{job.logoText}</span>
          ) : (
            <img src={job.logo} alt={job.company} width="40" height="40" />
          )}
        </div>

        <div class="company-content">
          <div class="company-header">
            <h3 class="company-name">{job.company}</h3>
            <span class="company-period">{job.period}</span>
          </div>
          {job.description && (
            <p class="company-description">{job.description}</p>
          )}

          {job.roles && job.roles.length > 0 && (
            <div class="roles-list">
              {job.roles.map((role) => (
                <div class="role-item">
                  <span class="role-dot"></span>
                  <div class="role-content">
                    <span class="role-title">{role.title}</span>
                    <span class="role-period">{role.period}</span>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <!-- <button class="load-more">
    {t.experience.loadMore}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button> -->
</section>

<style>
  .experience-section {
    background-color: #0a0a0a;
    color: #e5e5e5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    padding: 1.25rem var(--gutter) 1.5rem;
    max-width: var(--content-width, 100%);
    margin: 0 auto;
    width: 100%;
  }

  .section-title {
    font-size: 14px;
    font-weight: 400;
    color: #a3a3a3;
    margin: 0 0 20px 0;
    letter-spacing: 0.01em;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .experience-list {
      gap: 28px;
    }
  }

  .experience-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .company-logo {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: white;
    border: 1px solid #2a2a2a;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 1px;
  }

  .company-logo img {
    width: 44px;
    height: 44px;
    object-fit: cover;
    border-radius: 10px;
  }

  .logo-text {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
  }

  .company-content {
    flex: 1;
    min-width: 0;
  }

  .company-header {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-bottom: 6px;
  }

  .company-name {
    font-size: 15px;
    font-weight: 600;
    color: #f5f5f5;
    margin: 0;
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .company-name {
      font-size: 16px;
    }
  }

  .company-period {
    font-size: 13px;
    color: #737373;
    line-height: 1.4;
  }

  .company-description {
    font-size: 14px;
    color: #a3a3a3;
    margin: 0 0 14px 0;
    line-height: 1.55;
  }

  .roles-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .role-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 8px 0;
    position: relative;
  }

  .role-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 22px;
    bottom: -8px;
    width: 1px;
    background: #2a2a2a;
  }

  .role-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #3a3a3a;
    border: 1.5px solid #555;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .role-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .role-title {
    font-size: 14px;
    font-weight: 600;
    color: #e5e5e5;
    line-height: 1.4;
  }

  .role-period {
    font-size: 13px;
    color: #737373;
    line-height: 1.4;
  }

  .load-more {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 24px auto 0;
    background: none;
    border: none;
    color: #a3a3a3;
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    padding: 8px 16px;
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
    width: 100%;
    justify-content: center;
  }

  .load-more:hover {
    color: #f5f5f5;
    background: #1a1a1a;
  }

  .load-more svg {
    transition: transform 0.15s ease;
  }

  .load-more:hover svg {
    transform: translateY(2px);
  }
</style>
