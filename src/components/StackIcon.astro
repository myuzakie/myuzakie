---
interface Props {
  icon: string;
  color?: string;
}

const { icon, color = 'currentColor' } = Astro.props;
const label = typeof icon === 'string' && icon.length > 0
  ? icon[0].toUpperCase()
  : '?';
---

<svg
  viewBox="0 0 24 24"
  role="img"
  aria-label={icon}
  xmlns="http://www.w3.org/2000/svg"
>
  <rect
    x="2.5"
    y="2.5"
    width="19"
    height="19"
    rx="4"
    fill="none"
    stroke={color}
    stroke-width="1.5"
  />
  <text
    x="12"
    y="15"
    text-anchor="middle"
    font-size="10"
    font-family="var(--font-mono)"
    fill={color}
  >
    {label}
  </text>
</svg>
