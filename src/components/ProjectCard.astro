---
interface Props {
  title: string;
  description?: string;
  image: string;
  href?: string;
  theme?: "dark" | "light";
  tags?: string[];
  i18nTitle?: string;
  i18nDesc?: string;
}

const {
  title,
  description = "",
  image,
  href = "#",
  theme = "dark",
  tags = [],
  i18nTitle,
  i18nDesc,
} = Astro.props;
---

<a
  href={href}
  aria-label={title}
  class="group relative flex h-full flex-col rounded-lg overflow-hidden border border-border transition-transform duration-base min-w-0 no-underline hover:-translate-y-[3px] hover:border-border-light"
  class:list={[theme === "dark" ? "bg-surface" : "bg-[#f3f3f3]"]}
>
  <div
    class:list={[
      "relative h-full w-full overflow-hidden",
      theme === "dark" ? "bg-[#1d1d1d]" : "bg-[#e6e6e6]",
    ]}
  >
    <img
      src={image}
      alt={title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-base group-hover:scale-[1.02]"
    />
    <div
      class="absolute inset-0 flex items-center justify-center bg-black/0 backdrop-blur-[0px] transition-all duration-base group-hover:bg-black/20 group-hover:backdrop-blur-[2px]"
    >
      <span
        class="inline-flex items-center rounded-full border border-white/30 bg-white/85 px-4 py-2 font-mono text-[0.72rem] font-semibold uppercase tracking-[0.1em] text-[#111] opacity-0 translate-y-2 shadow-[0_10px_30px_rgba(0,0,0,0.18)] transition-all duration-base group-hover:opacity-100 group-hover:translate-y-0"
      >
        See Project
      </span>
    </div>
  </div>
</a>
