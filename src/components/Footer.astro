---
import { getTranslation } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'id' | 'de';
}
const { lang = 'en' } = Astro.props;
const t = getTranslation(lang as any);
---

<footer class="fixed bottom-0 left-0 right-0 z-[100] pointer-events-none">
  <!-- Floating dock bar -->
  <div class="pointer-events-auto flex items-center justify-between bg-surface border border-border rounded-full px-2 sm:px-3.5 py-1.5 sm:py-2 w-fit max-w-[calc(100%-var(--gutter)*2)] gap-1 sm:gap-2 fixed left-1/2 bottom-[calc(1rem+var(--safe-bottom,0px))] sm:bottom-7 -translate-x-1/2 shadow-[0_10px_30px_rgba(0,0,0,0.35)] backdrop-blur-[8px]">
    <!-- Left icons -->
    <div class="flex gap-0.5 flex-shrink-0">
      <!-- Sun / brightness -->
      <button
        class="w-8 h-8 sm:w-[34px] sm:h-[34px] rounded-full flex items-center justify-center text-text-secondary transition-colors duration-fast hover:bg-surface2 hover:text-text-primary"
        aria-label="Toggle theme"
        title={t.footer.theme}
        data-i18n-footer="theme"
        data-theme-toggle
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </button>
      <!-- Globe -->
      <button
        class="w-8 h-8 sm:w-[34px] sm:h-[34px] rounded-full flex items-center justify-center text-text-secondary transition-colors duration-fast hover:bg-surface2 hover:text-text-primary"
        aria-label="Globe / location"
        title={t.footer.location}
        data-i18n-footer="location"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
      </button>
      <!-- Chat / Comment Mode toggle -->
      <button
        id="chat-comment-btn"
        class="w-8 h-8 sm:w-[34px] sm:h-[34px] rounded-full flex items-center justify-center text-text-secondary transition-all duration-fast hover:bg-surface2 hover:text-text-primary"
        aria-label="Toggle comment mode"
        title="Comment mode (C)"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </button>
    </div>

    <!-- Language switcher — active state managed by JS via data-active attribute -->
    <div class="flex gap-0.5 sm:gap-1 ml-1 sm:ml-3 flex-shrink-0" role="group" aria-label="Language">
      {(['en', 'id', 'de'] as const).map(l => (
        <button
          class="lang-switch-btn px-2 sm:px-3 py-1 sm:py-1.5 rounded-full font-mono text-[0.65rem] sm:text-[0.72rem] font-medium tracking-[0.06em] transition-all duration-fast cursor-pointer border border-transparent bg-transparent text-text-secondary hover:text-text-primary"
          data-lang={l}
          aria-current={lang === l ? 'page' : undefined}
        >
          {l.toUpperCase()}
        </button>
      ))}
    </div>
  </div>
</footer>
