---
import type { Project, ProjectContent, ProjectLabels, ProfileInfo } from '../lib/projects';
import { getProjectMediaPaths } from '../lib/projects';

interface Props {
  project: Project;
  content: ProjectContent;
  profile: ProfileInfo;
  labels: ProjectLabels;
  counterText: string;
  descriptionParagraphs: string[];
  backHref: string;
  backLabel?: string;
}

const {
  project,
  content,
  profile,
  labels,
  counterText,
  descriptionParagraphs,
  backHref,
  backLabel,
} = Astro.props;

// Build the full list of media paths for this project
const mediaPaths = getProjectMediaPaths(project);
const hasMultiple = mediaPaths.length > 1;
const sliderId = `media-slider-${project.slug}`;
---

<main id="main-content" class="p-10 sm:pb-10">
  <div class="project-case-layout">
    <aside class="project-case-sidebar pt-6" aria-label="Project metadata" data-tour="project-metadata">
      <div class="project-case-field">
        <a
          href={backHref}
          class="inline-block mb-6 font-mono text-[0.75rem] text-text-muted border-b border-border-light pb-px transition-colors duration-fast hover:text-text-primary hover:border-text-secondary"
          data-i18n-case-label="back"
        >
          {backLabel ?? labels.back}
        </a>
      </div>
      <div class="project-case-field">
        <p class="project-case-label" data-i18n-case-label="title">{labels.title}</p>
        <p class="project-case-value project-case-value--strong" data-i18n-case-value="title">{content.title}</p>
      </div>
      <div class="project-case-field">
        <p class="project-case-label" data-i18n-case-label="year">{labels.year}</p>
        <p class="project-case-value" data-i18n-case-value="year">{content.year}</p>
      </div>
      <div class="project-case-field" data-tour="project-role">
        <p class="project-case-label" data-i18n-case-label="role">{labels.role}</p>
        <p class="project-case-value" data-i18n-case-value="role">{content.role}</p>
      </div>
      <div class="project-case-field" data-tour="project-publication-link">
        <p class="project-case-label" data-i18n-case-label="link">{labels.link}</p>
        <p class="project-case-value">
          <a
            href={content.publicationLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent-blue border-b border-current pb-px transition-opacity duration-fast hover:opacity-70"
            data-i18n-case-value="publicationLabel"
          >
            {content.publicationLabel}
          </a>
        </p>
      </div>
    </aside>

    <div class="project-case-main">
      <div data-tour="project-main">
        <div class="project-case-description-head">
          <p class="project-case-label" data-i18n-case-label="description">{labels.description}</p>
          <p class="project-case-counter" data-i18n-case-value="counter">{counterText}</p>
        </div>

        <div class="project-case-description" data-i18n-case-value="description" data-tour="project-description">
          {descriptionParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <!-- ── Media Gallery Slider ─────────────────────── -->
      <figure class="pcs-figure" data-tour="project-preview" id={sliderId}>

        <!-- Track: all slides side by side -->
        <div class="pcs-track-wrap">
          <div class="pcs-track" role="list" aria-label="Project media gallery">
            {mediaPaths.map((src, i) => {
              const isGif = src.toLowerCase().endsWith('.gif');
              const isFirst = i === 0;
              return (
                <div
                  class="pcs-slide"
                  role="listitem"
                  aria-label={`Slide ${i + 1} of ${mediaPaths.length}`}
                  aria-hidden={i !== 0 ? 'true' : undefined}
                >
                  {isGif ? (
                    <img
                      src={src}
                      alt={`${content.title} — preview ${i + 1}`}
                      class="pcs-media pcs-media--gif"
                      loading={isFirst ? 'eager' : 'lazy'}
                      decoding="async"
                      width="1200"
                      height="675"
                    />
                  ) : (
                    <img
                      src={src}
                      alt={`${content.title} — preview ${i + 1}`}
                      class="pcs-media"
                      loading={isFirst ? 'eager' : 'lazy'}
                      decoding="async"
                      width="1200"
                      height="1000"
                    />
                  )}
                  {isGif && (
                    <span class="pcs-gif-badge" aria-hidden="true">GIF</span>
                  )}
                </div>
              );
            })}
          </div>
        </div>

        {/* Controls — only render when more than 1 media */}
        {hasMultiple && (
          <>
            <button
              class="pcs-btn pcs-btn--prev"
              aria-label="Previous image"
              data-slider-prev
              type="button"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            <button
              class="pcs-btn pcs-btn--next"
              aria-label="Next image"
              data-slider-next
              type="button"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>

            {/* Dot indicators */}
            <div class="pcs-dots" role="tablist" aria-label="Slide indicators">
              {mediaPaths.map((_, i) => (
                <button
                  class={`pcs-dot${i === 0 ? ' pcs-dot--active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-label={`Go to slide ${i + 1}`}
                  data-slide-index={i}
                  type="button"
                />
              ))}
            </div>

            {/* Counter badge */}
            <div class="pcs-counter" aria-live="polite" aria-atomic="true">
              <span class="pcs-counter-current">1</span>
              <span class="pcs-counter-sep">/</span>
              <span class="pcs-counter-total">{mediaPaths.length}</span>
            </div>
          </>
        )}
      </figure>

      <slot name="appendix"/>
    </div>
  </div>

  <footer class="project-case-footer">
    <div class="project-case-footer-col">
      <p class="project-case-label" data-i18n-case-label="footerName">{labels.footerName}</p>
      <p class="project-case-footer-value" data-i18n-case-value="name">{profile.name}</p>
    </div>
    <div class="project-case-footer-col">
      <p class="project-case-label" data-i18n-case-label="footerUniversity">{labels.footerUniversity}</p>
      <p class="project-case-footer-value" data-i18n-case-value="university">{profile.university}</p>
    </div>
    <div class="project-case-footer-col">
      <p class="project-case-label" data-i18n-case-label="footerContact">{labels.footerContact}</p>
      <p class="project-case-footer-value" data-i18n-case-value="contact">{profile.contact}</p>
    </div>
    <div class="project-case-footer-col project-case-footer-col--note">
      <p class="project-case-footer-note" data-i18n-case-value="footerNote">{profile.footerNote}</p>
    </div>
  </footer>
</main>

<style>
  .project-case-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .project-case-layout {
      grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
      gap: 2rem 2.5rem;
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .project-case-layout {
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 2.5rem 3rem;
    }
  }

  .project-case-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .project-case-sidebar {
      position: sticky;
      top: calc(1.5rem + var(--safe-top, 0px));
    }
  }

  .project-case-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-case-field {
    min-width: 0;
  }

  .project-case-label {
    margin: 0 0 0.3rem;
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-primary, #f0f0f0);
  }

  .project-case-value {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-text-secondary, #9a9a9a);
    word-break: break-word;
  }

  .project-case-value--strong {
    color: var(--color-text-primary, #f0f0f0);
    font-weight: 600;
  }

  .project-case-description-head {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  @media (min-width: 640px) {
    .project-case-description-head {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  .project-case-counter {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--color-text-muted, #5e5e5e);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-case-description {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-case-description :global(p) {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-text-secondary, #9a9a9a);
  }

  /* ─── old single-image styles kept for compatibility ─── */
  .project-case-media {
    margin: 0.5rem 0 0;
    border: 1px solid #262626;
    border-radius: 6px;
    overflow: hidden;
    background: #141414;
  }

  .project-case-image {
    display: block;
    width: 100%;
    height: auto;
    min-height: 200px;
    max-height: min(72vh, 680px);
    object-fit: cover;
    object-position: center top;
  }

  @media (min-width: 768px) {
    .project-case-image {
      min-height: 320px;
    }
  }

  /* ─── Media Gallery Slider ──────────────────────────────── */
  .pcs-figure {
    position: relative;
    margin: 0.5rem 0 0;
    border: 1px solid #262626;
    border-radius: 6px;
    overflow: hidden;
    background: #141414;
    /* prevent layout shift */
    aspect-ratio: 16 / 9;
    min-height: 200px;
    max-height: min(72vh, 680px);
  }

  @media (min-width: 768px) {
    .pcs-figure {
      min-height: 320px;
    }
  }

  /* Track wrapper — clips to figure bounds */
  .pcs-track-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* Horizontal strip of slides */
  .pcs-track {
    display: flex;
    height: 100%;
    /* GPU-accelerated translate — no reflow */
    will-change: transform;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .pcs-slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #141414;
  }

  /* Keep the full image visible inside the gallery frame. */
  .pcs-media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    background: #141414;
  }

  /* GIF badge */
  .pcs-gif-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 2px 7px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    backdrop-filter: blur(4px);
    pointer-events: none;
    user-select: none;
  }

  /* ─── Prev / Next buttons ─────────────────────────────── */
  .pcs-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.48);
    color: #fff;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition: background 0.15s ease, opacity 0.15s ease, transform 0.15s ease;
    opacity: 0;
  }

  .pcs-figure:hover .pcs-btn,
  .pcs-figure:focus-within .pcs-btn {
    opacity: 1;
  }

  .pcs-btn--prev { left: 10px; }
  .pcs-btn--next { right: 10px; }

  .pcs-btn:hover {
    background: rgba(0, 0, 0, 0.72);
  }

  .pcs-btn:disabled {
    opacity: 0.25 !important;
    cursor: default;
  }

  /* ─── Dot indicators ──────────────────────────────────── */
  .pcs-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 5px;
    z-index: 10;
  }

  .pcs-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .pcs-dot--active {
    background: #fff;
    transform: scale(1.25);
  }

  /* ─── Counter badge ───────────────────────────────────── */
  .pcs-counter {
    position: absolute;
    top: 10px;
    right: 10px;
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    font-family: 'DM Mono', monospace;
    background: rgba(0, 0, 0, 0.5);
    color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
    pointer-events: none;
  }

  .pcs-counter-sep {
    margin: 0 1px;
    opacity: 0.5;
  }
</style>

<script>
  /** ── Media Gallery Slider ─────────────────────────────── */
  function initSliders() {
    document.querySelectorAll<HTMLElement>('[data-tour="project-preview"]').forEach((figure) => {
      const track     = figure.querySelector<HTMLElement>('.pcs-track');
      const slides    = figure.querySelectorAll<HTMLElement>('.pcs-slide');
      const prevBtn   = figure.querySelector<HTMLButtonElement>('[data-slider-prev]');
      const nextBtn   = figure.querySelector<HTMLButtonElement>('[data-slider-next]');
      const dots      = figure.querySelectorAll<HTMLButtonElement>('[data-slide-index]');
      const counter   = figure.querySelector<HTMLElement>('.pcs-counter-current');

      if (!track || slides.length <= 1) return;

      let current = 0;
      const total = slides.length;

      // No manual lazy load needed, browser handles loading="lazy"

      // ── Go to slide ────────────────────────────────────────
      function goTo(index: number, animate = true) {
        const clamped = Math.max(0, Math.min(total - 1, index));
        current = clamped;

        if (!animate) track.style.transition = 'none';
        track.style.transform = `translateX(-${clamped * 100}%)`;
        if (!animate) {
          // force reflow then re-enable transition
          track.getBoundingClientRect();
          track.style.transition = '';
        }

        // Aria
        slides.forEach((s, i) => {
          s.setAttribute('aria-hidden', i !== clamped ? 'true' : 'false');
        });

        // Dots
        dots.forEach((dot, i) => {
          dot.classList.toggle('pcs-dot--active', i === clamped);
          dot.setAttribute('aria-selected', i === clamped ? 'true' : 'false');
        });

        // Counter
        if (counter) counter.textContent = String(clamped + 1);

        // Buttons
        if (prevBtn) prevBtn.disabled = clamped === 0;
        if (nextBtn) nextBtn.disabled = clamped === total - 1;
      }

      goTo(0, false);

      // ── Event listeners ─────────────────────────────────────
      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = Number(dot.dataset.slideIndex ?? 0);
          goTo(idx);
        });
      });

      // Keyboard: ← → when figure or its children focused
      figure.setAttribute('tabindex', '0');
      figure.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(current - 1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); }
      });

      // ── Touch / swipe support ───────────────────────────────
      let touchStartX = 0;
      let touchDeltaX = 0;
      const SWIPE_THRESHOLD = 40; // px

      figure.addEventListener('touchstart', (e: TouchEvent) => {
        touchStartX = e.touches[0].clientX;
        touchDeltaX = 0;
        track.style.transition = 'none';
      }, { passive: true });

      figure.addEventListener('touchmove', (e: TouchEvent) => {
        touchDeltaX = e.touches[0].clientX - touchStartX;
        // Live drag feedback
        const offset = current * 100;
        const percent = (touchDeltaX / figure.offsetWidth) * 100;
        track.style.transform = `translateX(calc(-${offset}% + ${touchDeltaX}px))`;
      }, { passive: true });

      figure.addEventListener('touchend', () => {
        track.style.transition = '';
        if (touchDeltaX < -SWIPE_THRESHOLD) goTo(current + 1);
        else if (touchDeltaX > SWIPE_THRESHOLD) goTo(current - 1);
        else goTo(current); // snap back
        touchDeltaX = 0;
      });
    });
  }

  // Run on first load and after View Transitions
  document.addEventListener('DOMContentLoaded', initSliders);
  document.addEventListener('astro:after-swap', initSliders);
</script>

<style>
  /* ─── Footer styles ─────────────────────────────────────── */
  .project-case-footer {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid #262626;
  }

  @media (min-width: 640px) {
    .project-case-footer {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .project-case-footer {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      padding-top: 1.5rem;
    }
  }

  .project-case-footer-col {
    min-width: 0;
  }

  .project-case-footer-value {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-text-muted, #5e5e5e);
    word-break: break-word;
  }

  .project-case-footer-col--note {
    display: flex;
    align-items: flex-end;
  }

  @media (max-width: 1023px) {
    .project-case-footer-col--note {
      grid-column: 1 / -1;
      align-items: flex-start;
    }
  }

  .project-case-footer-note {
    margin: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--color-text-secondary, #9a9a9a);
  }
</style>
