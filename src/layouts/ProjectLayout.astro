---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'id' | 'de';
  noindex?: boolean;
}

const { title, description = '', lang = 'en', noindex = false } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang} noindex={noindex}>
  <Footer lang={lang} />

  <div class="layout-shell layout-shell--project">
    <slot />
  </div>
</BaseLayout>
